{
    "name": "mtv",
    "version": "2.0.0",
    "private": true,
    "type": "module",
    "description": "mtv.example.com — a modern music video jukebox",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "server": "node app/server/src/index.js",
        "web": "vite",
        "dev": "concurrently -n server,web -c blue,magenta \"npm:server\" \"npm:web\"",
        "build": "vite build",
        "import": "node scripts/import.js",
        "format": "prettier --write .",
        "lint": "eslint ."
    },
    "dependencies": {
        "@emotion/react": "^11.13.3",
        "@emotion/styled": "^11.13.0",
        "@mui/icons-material": "^6.1.6",
        "@mui/material": "^6.1.6",
        "better-sqlite3": "^11.5.0",
        "cookie-parser": "^1.4.7",
        "express": "^4.21.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.28.0",
        "socket.io": "^4.8.1",
        "socket.io-client": "^4.8.1",
        "zustand": "^5.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.14.0",
        "@vitejs/plugin-react": "^4.3.3",
        "concurrently": "^9.1.0",
        "eslint": "^9.14.0",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^15.12.0",
        "prettier": "^3.3.3",
        "vite": "^5.4.10"
    },
    "prettier": {
        "printWidth": 130,
        "tabWidth": 4,
        "trailingComma": "none",
        "semi": false
    }
}
